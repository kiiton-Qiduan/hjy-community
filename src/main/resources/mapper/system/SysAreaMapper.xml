<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.msb.hjycommunity.system.mapper.SysAreaMapper">

    <select id="selectAreaList" resultType="com.msb.hjycommunity.system.domain.SysArea">
        select
            id,
            code,
            name,
            parentid,
            level,
            type,
            servicestate,
            delete_flag,
            region
        from sys_area
        where delete_flag = 0
        order by parentid, code
    </select>

</mapper>
